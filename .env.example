# Akselerja environment variables
# Copy to .env.local and fill in. Vars are grouped by whether the app needs
# them to function. In production, the REQUIRED group is asserted at boot
# (see instrumentation.ts) and the app refuses to start if any are missing.

# ============================================================
# REQUIRED (production fails to boot without these)
# ============================================================

# next-auth signing secret. Generate: `openssl rand -base64 32`.
# Missing -> every protected API returns 401, no session can be minted.
AUTH_SECRET=

# Azure Cosmos DB. Missing -> all persistence is empty/erroring (profiles,
# jobs, attempts, AI cache). The app looks up but core flows are dead.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=akselerja

# Google Gemini (free tier). Powers CV parsing, embeddings, coach, gap
# explanations, practice/checkpoint generation. Missing -> those features fail.
GEMINI_API_KEY=

# Public base URL of the deployment. Used for password-reset links and OAuth
# callbacks. Set at least one. Missing in production -> reset links throw.
NEXT_PUBLIC_APP_URL=https://your-domain.example

# Resend transactional email (password reset). RESEND_FROM MUST be a verified
# sender domain in production; the sandbox default only delivers to the Resend
# account owner, so real users never receive reset emails.
RESEND_API_KEY=
RESEND_FROM=Akselerja <no-reply@your-domain.example>

# ============================================================
# OPTIONAL (app degrades gracefully if absent)
# ============================================================

# Google OAuth sign-in. Without these, only email+password login works.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alternate names for the app URL (any one of these or NEXT_PUBLIC_APP_URL).
APP_URL=
AUTH_URL=
NEXTAUTH_URL=

# Azure AI Search (hybrid vector + BM25 job search). Missing -> falls back to
# an in-memory Cosmos scan with flatter relevance (worse ranking, more RU).
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_JOBS=jobs-v1

# Azure Blob Storage (CV file storage). Provide the connection string OR the
# account name + key. Missing -> CV is parsed but the file is not stored.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CV_CONTAINER=cv
BLOB_CONTAINER_CV=cv

# Gemini model overrides (sensible defaults exist in code).
GEMINI_MODEL=
GEMINI_CHAT_MODEL=
GEMINI_EMBED_MODEL=

# Qwen fallback for chat/JSON when Gemini is rate-limited. Missing -> no
# fallback; the coach degrades to a static message when Gemini is down.
QWEN_API_KEY=

# YouTube Data API (learning material videos). Missing/quota-exhausted ->
# learning pages show no video material (falls back to search links).
YOUTUBE_API_KEY=

# Azure Content Safety (moderation for coach input/output). Missing -> coach
# runs WITHOUT moderation (fails open). Set AZURE_CONTENT_SAFETY_FAIL_CLOSED=1
# to block on API errors, AZURE_CONTENT_SAFETY_CHECK_OUTPUT=1 to also moderate
# generated text.
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=
AZURE_CONTENT_SAFETY_FAIL_CLOSED=
AZURE_CONTENT_SAFETY_CHECK_OUTPUT=

# ============================================================
# TEST ONLY — never set in production
# ============================================================
# Enables the /api/test/sign-in backdoor and non-secure cookies for E2E.
# The route is additionally hard-gated to refuse when NODE_ENV=production.
E2E_MODE=
